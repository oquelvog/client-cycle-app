generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id // Clerk user ID
  onboarded    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  reviewCycles ReviewCycle[]
  clients      Client[]
}

model ReviewCycle {
  id         String      @id @default(cuid())
  name       String
  advisorId  String
  advisor    User        @relation(fields: [advisorId], references: [id], onDelete: Cascade)
  milestones Milestone[]
  clients    Client[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @default(now()) @updatedAt
}

enum DurationType {
  specific_date
  month
  quarter
}

model Milestone {
  id             String       @id @default(cuid())
  title          String
  description    String?
  dayOfYear      Int
  endDayOfYear   Int
  durationType   DurationType @default(specific_date)
  color          String       @default("#6366f1")
  order          Int          @default(0)
  reviewCycleId  String
  reviewCycle    ReviewCycle  @relation(fields: [reviewCycleId], references: [id], onDelete: Cascade)
  checkIns       CheckIn[]
  currentClients Client[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt
}

model CheckIn {
  id             String          @id @default(cuid())
  title          String
  description    String?
  dayOfYear      Int
  milestoneId    String
  milestone      Milestone       @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  tasks          Task[]
  clientCheckIns ClientCheckIn[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @default(now()) @updatedAt
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  checkInId   String
  checkIn     CheckIn      @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  clientTasks ClientTask[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt
}

model Client {
  id                 String          @id @default(cuid())
  name               String
  color              String          @default("#6366f1")
  tags               String[]
  notes              String?
  lastContacted      DateTime?
  cycleYear          Int             @default(2025)
  reviewCycleId      String
  reviewCycle        ReviewCycle     @relation(fields: [reviewCycleId], references: [id])
  currentMilestoneId String?
  currentMilestone   Milestone?      @relation(fields: [currentMilestoneId], references: [id])
  advisorId          String
  advisor            User            @relation(fields: [advisorId], references: [id], onDelete: Cascade)
  clientTasks        ClientTask[]
  clientCheckIns     ClientCheckIn[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @default(now()) @updatedAt
}

enum TaskStatus {
  pending
  completed
}

model ClientTask {
  id          String     @id @default(cuid())
  clientId    String
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  taskId      String
  task        Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  status      TaskStatus @default(pending)
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt

  @@unique([clientId, taskId])
}

model ClientCheckIn {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  checkInId   String
  checkIn     CheckIn   @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  @@unique([clientId, checkInId])
}
